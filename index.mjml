        </mj-column>
      </mj-section>
    </mj-wrapper>


    <mj-section full-width="full-width" padding="20px 0 17px" mj-class="bg-footer">
      <mj-column width="100%" padding="0 0 20px">
        <mj-text mj-class="fontSizeText-16 light" align="center">
          <!--!-------------------------------------TEXT-------------------------------------------->
          <a href="https://mjml.io" target="_blank" style=" color:#fff;">Unsubscribe</a>
        </mj-text>
      </mj-column>
      <mj-column width="14%" css-class="foo">
        <!--!-------------------------------------LOGO FOOTER---------------------------------------->
        <mj-image src="./img/only.png" alt="footer_logo" align="center" width="38px" padding="0 0 15px" />
      </mj-column>
      <mj-column width="22%" css-class="foo">
        <mj-text mj-class="fontSizeText-12 grey" align="left" css-class="text-fix" padding="0 0 15px">
          <!--!-------------------------------------TEXT---------------------------------------->
          2026 © Vegas <br> All rights reserved
        </mj-text>
      </mj-column>
