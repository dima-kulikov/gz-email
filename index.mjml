            <!--!-------------------------------------TEXT-------------------------------------------->
            Deposit from €25
          </mj-text>
        </mj-column>
      </mj-section>


      <mj-section full-width="full-width" padding="20px 0 0">
        <mj-column width="100%" padding="0">
          <mj-text mj-class="fontSizeText-16 light" align="left">
