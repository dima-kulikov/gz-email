          <mj-button href="https://mjml.io" mj-class="fontSizeText-14" border-radius="24px" border="1px dashed #999FFF" background-color="#FFF5DD" color="#8D19E8">
            Reactoonz_3
          </mj-button>
        </mj-column>
      </mj-section>

      <mj-section full-width="full-width" padding="20px 0 0">
       
      </mj-section>

      <mj-section full-width="full-width" background-color="#FFECBE" border-radius="20px" padding="20px 0">
        <mj-column width="10%" vertical-align="middle">
          <!--!------------------------------------ IMG---------------------------------------->
          <mj-image src="./img/logo.jpg" alt="prize" css-class="img-prize" />
        </mj-column>
        <!--!-------------------------------------TEXT---------------------------------------->
        <mj-column width="25%" vertical-align="middle" css-class="text-prize">
          <mj-text align="center" mj-class="fontSizeText-14">
            <p style="border: 1px solid #999FFF; color: #8D19E8; border-radius: 20px; background: #FFF5DD; display: inline-block; padding:5px; margin:0 0 4px; width: 100px;">
              Bonus 20%
            </p>
            <!--!-------------------------------------TEXT---------------------------------------->
            <p style="border:1px solid #999FFF; color: #8D19E8; border-radius: 20px; background: #FFF5DD; display: inline-block; padding:5px; margin:0; width: 100px;">
