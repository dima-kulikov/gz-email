          </mj-text>
          <mj-text align="center" mj-class="fontSizeSecond-12" padding="0">
            <span style=" color: #1A59FB;">
              Bigg Bass Bonanza
            </span>
          </mj-text>
        </mj-column>
        <!--!-------------------------------------TEXT---------------------------------------->
        <mj-column width="25%" vertical-align="middle" css-class="text-bonus">
          <mj-text align="center" mj-class="fontSizeSecond-12" color="#1E1D5A" css-class="text-fix" padding="0 0 8px">
